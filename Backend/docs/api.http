### AssetFlow Phase 1 & 2 — API Verification Sequence
### Use with VS Code REST Client extension

@baseUrl = http://localhost:3000/api
@adminEmail = admin@assetflow.io
@adminPassword = Admin@1234

### ─────────────────────────────────────────────
### 1. SIGN UP a new employee
### ─────────────────────────────────────────────
# @name signup
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "name": "Jane Doe",
  "email": "jane.doe@assetflow.io",
  "password": "JaneDoe@123"
}

### ─────────────────────────────────────────────
### 2. LOG IN as the new employee
### ─────────────────────────────────────────────
# @name employeeLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "jane.doe@assetflow.io",
  "password": "JaneDoe@123"
}

@employeeToken = {{employeeLogin.response.body.data.token}}

### ─────────────────────────────────────────────
### 3. LOG IN as the seeded ADMIN
### ─────────────────────────────────────────────
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

@adminToken = {{adminLogin.response.body.data.token}}

### ─────────────────────────────────────────────
### 4. ADMIN creates a department
### ─────────────────────────────────────────────
# @name createDept
POST {{baseUrl}}/departments
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Product",
  "status": "ACTIVE"
}

### ─────────────────────────────────────────────
### 5. GET all employees (as admin) to find Jane's id
### ─────────────────────────────────────────────
GET {{baseUrl}}/employees?search=jane
Authorization: Bearer {{adminToken}}

### ─────────────────────────────────────────────
### 6. ADMIN promotes Jane to ASSET_MANAGER
###    Replace <JANE_ID> with the id from step 5
### ─────────────────────────────────────────────
# @name promote
PATCH {{baseUrl}}/employees/<JANE_ID>
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "roles": ["ASSET_MANAGER"]
}

### ─────────────────────────────────────────────
### 7. CONFIRM — GET employees, Jane should now have ASSET_MANAGER role
### ─────────────────────────────────────────────
GET {{baseUrl}}/employees?search=jane
Authorization: Bearer {{adminToken}}

### ─────────────────────────────────────────────
### 8. (Optional) Jane logs in again — re-issued token will carry new role
### ─────────────────────────────────────────────
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "jane.doe@assetflow.io",
  "password": "JaneDoe@123"
}

### ─────────────────────────────────────────────
### 9. GET categories (authenticated)
### ─────────────────────────────────────────────
GET {{baseUrl}}/categories
Authorization: Bearer {{employeeToken}}

### ─────────────────────────────────────────────
### 10. ADMIN creates a category
### ─────────────────────────────────────────────
POST {{baseUrl}}/categories
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Headsets",
  "description": "Audio headsets and peripherals",
  "customFields": { "warrantyPeriodMonths": 12 }
}

### ─────────────────────────────────────────────
### 11. LOGOUT (stateless — client discards token)
### ─────────────────────────────────────────────
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{employeeToken}}

###
### ═════════════════════════════════════════════
### PHASE 2 — Asset Registry Verification
### ═════════════════════════════════════════════

### ─────────────────────────────────────────────
### P2-1. Admin login (reuse seeded admin)
### ─────────────────────────────────────────────
# @name p2AdminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@assetflow.io",
  "password": "Admin@1234"
}

@p2AdminToken = {{p2AdminLogin.response.body.data.token}}

### ─────────────────────────────────────────────
### P2-2. GET categories (need categoryId for asset creation)
### ─────────────────────────────────────────────
# @name getCategories
GET {{baseUrl}}/categories
Authorization: Bearer {{p2AdminToken}}

### ─────────────────────────────────────────────
### P2-3. Register a new asset as Admin
###       Seed already created AF-0001 to AF-0005,
###       so this should auto-generate AF-0006
### ─────────────────────────────────────────────
# @name registerAsset
POST {{baseUrl}}/assets
Content-Type: application/json
Authorization: Bearer {{p2AdminToken}}

{
  "name": "HP EliteDesk Desktop",
  "categoryId": "<PASTE_LAPTOP_CATEGORY_ID_FROM_P2-2>",
  "serialNumber": "SN-HP-ELITE-006",
  "acquisitionDate": "2026-07-12T00:00:00Z",
  "acquisitionCost": 899.00,
  "condition": "NEW",
  "location": "Operations Room",
  "isBookable": false,
  "photoUrls": []
}

@newAssetId = {{registerAsset.response.body.data.asset.id}}

### ─────────────────────────────────────────────
### P2-4. Search for the newly registered asset
### ─────────────────────────────────────────────
GET {{baseUrl}}/assets?search=HP+EliteDesk
Authorization: Bearer {{p2AdminToken}}

### ─────────────────────────────────────────────
### P2-5. GET full asset detail — confirm statusHistory
###       has "Asset registered" entry
### ─────────────────────────────────────────────
GET {{baseUrl}}/assets/{{newAssetId}}
Authorization: Bearer {{p2AdminToken}}

### ─────────────────────────────────────────────
### P2-6. PATCH asset — update location and condition
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/assets/{{newAssetId}}
Content-Type: application/json
Authorization: Bearer {{p2AdminToken}}

{
  "location": "Engineering Lab",
  "condition": "GOOD"
}

### ─────────────────────────────────────────────
### P2-7. PATCH status to ALLOCATED directly — should be rejected 400
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/assets/{{newAssetId}}
Content-Type: application/json
Authorization: Bearer {{p2AdminToken}}

{
  "status": "ALLOCATED"
}

### ─────────────────────────────────────────────
### P2-8. POST /api/assets as plain EMPLOYEE — should get 403
###       Use the employee token from Phase 1 login
### ─────────────────────────────────────────────
POST {{baseUrl}}/assets
Content-Type: application/json
Authorization: Bearer {{employeeToken}}

{
  "name": "Unauthorized Asset",
  "categoryId": "<ANY_CATEGORY_ID>"
}

### ─────────────────────────────────────────────
### P2-9. GET paginated asset list with filters
### ─────────────────────────────────────────────
GET {{baseUrl}}/assets?status=AVAILABLE&page=1&limit=5
Authorization: Bearer {{p2AdminToken}}

### ─────────────────────────────────────────────
### P2-10. PATCH status to RETIRED (allowed via this route)
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/assets/{{newAssetId}}
Content-Type: application/json
Authorization: Bearer {{p2AdminToken}}

{
  "status": "RETIRED"
}

###
### ═════════════════════════════════════════════
### PHASE 3A — Allocations & Transfers Verification
### ═════════════════════════════════════════════

### ─────────────────────────────────────────────
### P3-1. Admin login (reuse seeded admin)
### ─────────────────────────────────────────────
# @name p3AdminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@assetflow.io",
  "password": "Admin@1234"
}

@p3AdminToken = {{p3AdminLogin.response.body.data.token}}

### ─────────────────────────────────────────────
### P3-2. GET Assets to find an AVAILABLE one (e.g. AF-0002)
###       and the ALLOCATED one (AF-0001)
### ─────────────────────────────────────────────
# @name getP3Assets
GET {{baseUrl}}/assets
Authorization: Bearer {{p3AdminToken}}

@availableAssetId = {{getP3Assets.response.body.data[1].id}}
@allocatedAssetId = {{getP3Assets.response.body.data[0].id}}

### ─────────────────────────────────────────────
### P3-3. Get an employee ID to allocate to
### ─────────────────────────────────────────────
# @name getP3Employees
GET {{baseUrl}}/employees
Authorization: Bearer {{p3AdminToken}}

@targetEmpId = {{getP3Employees.response.body.data.employees[0].id}}

### ─────────────────────────────────────────────
### P3-4. Allocate the AVAILABLE asset (AF-0002)
### ─────────────────────────────────────────────
# @name createAllocation
POST {{baseUrl}}/allocations
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{availableAssetId}}",
  "allocatedToEmpId": "{{targetEmpId}}"
}

### ─────────────────────────────────────────────
### P3-5. Double Allocation test — try to allocate AF-0001
###       which was seeded as ALLOCATED. Should return 409
###       and the holder's name.
### ─────────────────────────────────────────────
POST {{baseUrl}}/allocations
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{allocatedAssetId}}",
  "allocatedToEmpId": "{{targetEmpId}}"
}

### ─────────────────────────────────────────────
### P3-6. Transfer Request for the newly allocated asset (AF-0002)
### ─────────────────────────────────────────────
# @name createTransfer
POST {{baseUrl}}/transfers
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{availableAssetId}}",
  "requestedToEmpId": "{{targetEmpId}}",
  "reason": "Moving teams"
}

@transferId = {{createTransfer.response.body.data.transfer.id}}

### ─────────────────────────────────────────────
### P3-7. Approve the Transfer
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/transfers/{{transferId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "action": "APPROVE"
}

### ─────────────────────────────────────────────
### P3-8. Return the asset (AF-0002) - Need to fetch allocations to get ID
### ─────────────────────────────────────────────
# @name getActiveAllocations
GET {{baseUrl}}/allocations?assetId={{availableAssetId}}&status=ACTIVE
Authorization: Bearer {{p3AdminToken}}

@activeAllocationId = {{getActiveAllocations.response.body.data.data[0].id}}

### ─────────────────────────────────────────────
### P3-9. Process the return
### ─────────────────────────────────────────────
POST {{baseUrl}}/allocations/{{activeAllocationId}}/return
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "checkInCondition": "FAIR",
  "checkInNotes": "Returned after transfer test"
}

### ─────────────────────────────────────────────
### P3-10. Verify Employee RBAC on Allocations
### ─────────────────────────────────────────────
GET {{baseUrl}}/allocations
Authorization: Bearer {{p3AdminToken}}

###
### ═════════════════════════════════════════════
### PHASE 3B — Bookings & Maintenance Verification
### ═════════════════════════════════════════════

### ─────────────────────────────────────────────
### P3B-1. GET Bookable and Non-Bookable Asset IDs
### ─────────────────────────────────────────────
# @name getP3BAssets
GET {{baseUrl}}/assets
Authorization: Bearer {{p3AdminToken}}

@bookableAssetId = {{getP3BAssets.response.body.data[2].id}} 
# AF-0003 is index 2
@nonBookableAssetId = {{getP3BAssets.response.body.data[0].id}} 
# AF-0001 is index 0

@maintenanceAssetId = {{getP3BAssets.response.body.data[3].id}} 
# AF-0004 is index 3

### ─────────────────────────────────────────────
### P3B-2. Attempt to book a non-bookable asset (AF-0001)
### ─────────────────────────────────────────────
POST {{baseUrl}}/bookings
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{nonBookableAssetId}}",
  "startTime": "2030-01-01T09:00:00.000Z",
  "endTime": "2030-01-01T10:00:00.000Z"
}

### ─────────────────────────────────────────────
### P3B-3. Book a bookable asset (AF-0003) for 9:00-10:00
### ─────────────────────────────────────────────
# @name createBooking
POST {{baseUrl}}/bookings
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{bookableAssetId}}",
  "startTime": "2030-01-01T09:00:00.000Z",
  "endTime": "2030-01-01T10:00:00.000Z",
  "purpose": "Strategy Sync"
}

### ─────────────────────────────────────────────
### P3B-4. Attempt to book the SAME asset for 9:30-10:30 (Overlap!)
### ─────────────────────────────────────────────
POST {{baseUrl}}/bookings
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{bookableAssetId}}",
  "startTime": "2030-01-01T09:30:00.000Z",
  "endTime": "2030-01-01T10:30:00.000Z"
}

### ─────────────────────────────────────────────
### P3B-5. Book back-to-back 10:00-11:00 (Allowed)
### ─────────────────────────────────────────────
POST {{baseUrl}}/bookings
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{bookableAssetId}}",
  "startTime": "2030-01-01T10:00:00.000Z",
  "endTime": "2030-01-01T11:00:00.000Z"
}

### ─────────────────────────────────────────────
### P3B-6. Raise a maintenance request
### ─────────────────────────────────────────────
# @name raiseMaintenance
POST {{baseUrl}}/maintenance
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "assetId": "{{maintenanceAssetId}}",
  "issueDescription": "Screen cracked during test",
  "priority": "HIGH"
}

@maintenanceReqId = {{raiseMaintenance.response.body.data.request.id}}

### ─────────────────────────────────────────────
### P3B-7. Approve Maintenance (flips asset to UNDER_MAINTENANCE)
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/maintenance/{{maintenanceReqId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "status": "APPROVED"
}

### ─────────────────────────────────────────────
### P3B-8. Verify Asset is UNDER_MAINTENANCE
### ─────────────────────────────────────────────
GET {{baseUrl}}/assets/{{maintenanceAssetId}}
Authorization: Bearer {{p3AdminToken}}

### ─────────────────────────────────────────────
### P3B-9. Invalid Transition Check (Jump to RESOLVED directly)
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/maintenance/{{maintenanceReqId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "status": "RESOLVED",
  "resolutionNotes": "Fixed screen"
}

### ─────────────────────────────────────────────
### P3B-10. Valid Transition (IN_PROGRESS)
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/maintenance/{{maintenanceReqId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "status": "IN_PROGRESS"
}

### ─────────────────────────────────────────────
### P3B-11. Valid Transition (RESOLVED) (flips back to AVAILABLE)
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/maintenance/{{maintenanceReqId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "status": "RESOLVED",
  "resolutionNotes": "Screen replaced successfully"
}

###
### ═════════════════════════════════════════════
### PHASE 4 — Audits, Dashboard, & Notifications Verification
### ═════════════════════════════════════════════

### ─────────────────────────────────────────────
### P4-1. Create an Audit Cycle
### ─────────────────────────────────────────────
# @name createAudit
POST {{baseUrl}}/audits
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "name": "Q3 Engineering Asset Audit",
  "startDate": "2024-01-01T00:00:00Z",
  "endDate": "2024-01-31T00:00:00Z",
  "auditorIds": ["{{targetEmpId}}"]
}

@auditCycleId = {{createAudit.response.body.data.cycle.id}}
@auditItem1 = {{createAudit.response.body.data.cycle.items[0].asset.id}}
@auditItem2 = {{createAudit.response.body.data.cycle.items[1].asset.id}}

### ─────────────────────────────────────────────
### P4-2. Verify an item as MISSING (simulating the auditor)
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/audits/{{auditCycleId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "action": "VERIFY",
  "assetId": "{{auditItem1}}",
  "result": "MISSING",
  "notes": "Could not find it in the office"
}

### ─────────────────────────────────────────────
### P4-3. Verify an item as DAMAGED
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/audits/{{auditCycleId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "action": "VERIFY",
  "assetId": "{{auditItem2}}",
  "result": "DAMAGED",
  "notes": "Screen is completely shattered"
}

### ─────────────────────────────────────────────
### P4-4. Close the Audit Cycle (Should cascade MISSING -> LOST)
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/audits/{{auditCycleId}}
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "action": "CLOSE"
}

### ─────────────────────────────────────────────
### P4-5. Fetch Dashboard KPIs
### ─────────────────────────────────────────────
GET {{baseUrl}}/dashboard/kpis
Authorization: Bearer {{p3AdminToken}}

### ─────────────────────────────────────────────
### P4-6. Fetch Dashboard Analytics
### ─────────────────────────────────────────────
GET {{baseUrl}}/dashboard/analytics
Authorization: Bearer {{p3AdminToken}}

### ─────────────────────────────────────────────
### P4-7. Fetch Notifications for the Auditor
### ─────────────────────────────────────────────
# @name getNotifications
GET {{baseUrl}}/notifications?unreadOnly=true
Authorization: Bearer {{p3AdminToken}}

@notificationId = {{getNotifications.response.body.data.data[0].id}}

### ─────────────────────────────────────────────
### P4-8. Bulk Mark Notifications Read
### ─────────────────────────────────────────────
PATCH {{baseUrl}}/notifications
Content-Type: application/json
Authorization: Bearer {{p3AdminToken}}

{
  "markAllRead": true
}

